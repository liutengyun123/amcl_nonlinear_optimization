<launch>
  <param name="use_sim_time" value="true"/>

  <arg name="map_yaml_path" default="/home/wr/cartographer/maprogess/pcd_and_grid_map/abtr251229/abtr251229_1.yaml"/>
  <arg name="publish_urdf" default="true"/>
  <arg name="urdf_path" default="/home/wr/cartographer/maprogess/dataset/abtr251229/abtr.urdf"/>

  <arg name="scan_topic" default="/ABTRTEST/scan"/>
  <arg name="odom_topic" default="/ABTRTEST/odom/wheel"/>
  <arg name="imu_topic" default="/ABTRTEST/imu"/>
  <arg name="initialpose_topic" default="/initialpose"/>

  <arg name="debug_verbose" default="true"/>
  <arg name="debug_log_throttle_sec" default="0.5"/>
  <arg name="debug_publish_scan_clouds" default="true"/>
  <arg name="debug_pred_scan_cloud_topic" default="csm_scan_pred_cloud"/>
  <arg name="debug_out_scan_cloud_topic" default="csm_scan_out_cloud"/>
  <arg name="predictor_enable" default="true"/>

  <arg name="map_frame_id" default="map"/>
  <arg name="base_frame_id" default="ABTRTEST/base_footprint"/>
  <arg name="odom_pub_topic" default="csm_odom"/>

  <arg name="startup_reloc_enable" default="true"/>
  <arg name="startup_reloc_allow_external_map_paths" default="true"/>
  <arg name="startup_reloc_map_yaml" default="$(arg map_yaml_path)"/>

  <group if="$(arg publish_urdf)">
    <param name="robot_description" textfile="$(arg urdf_path)"/>
    <node name="robot_state_publisher"
          pkg="robot_state_publisher"
          type="robot_state_publisher"
          output="screen"/>
  </group>

  <node pkg="localization_ndt"
        type="csm_localizer_node"
        name="csm_localizer"
        output="screen">
    <param name="map_yaml_path" value="$(arg map_yaml_path)"/>
    <param name="scan_topic" value="$(arg scan_topic)"/>
    <param name="odom_topic" value="$(arg odom_topic)"/>
    <param name="imu_topic" value="$(arg imu_topic)"/>
    <param name="initialpose_topic" value="$(arg initialpose_topic)"/>

    <param name="debug_verbose" value="$(arg debug_verbose)"/>
    <param name="debug_log_throttle_sec" value="$(arg debug_log_throttle_sec)"/>
    <param name="debug_publish_scan_clouds" value="$(arg debug_publish_scan_clouds)"/>
    <param name="debug_pred_scan_cloud_topic" value="$(arg debug_pred_scan_cloud_topic)"/>
    <param name="debug_out_scan_cloud_topic" value="$(arg debug_out_scan_cloud_topic)"/>
    <param name="predictor_enable" value="$(arg predictor_enable)"/>
    <param name="dr_mode_enable" value="true"/>
    <param name="dr_max_predict_distance_m" value="10.0"/>
    <param name="dr_max_predict_yaw_deg" value="270.0"/>
    <param name="dr_recover_accept_frames" value="3"/>

    <param name="map_frame_id" value="$(arg map_frame_id)"/>
    <param name="base_frame_id" value="$(arg base_frame_id)"/>
    <param name="odom_pub_topic" value="$(arg odom_pub_topic)"/>

    <param name="startup_reloc_enable" value="$(arg startup_reloc_enable)"/>
    <param name="startup_reloc_allow_external_map_paths" value="$(arg startup_reloc_allow_external_map_paths)"/>
    <param name="startup_reloc_map_yaml" value="$(arg startup_reloc_map_yaml)"/>
    <param name="lost_reloc_enable" value="true"/>
    <param name="lost_reloc_xy_range_m" value="3.0"/>
    <param name="lost_reloc_yaw_range_deg" value="45.0"/>
    <param name="lost_reloc_min_score" value="0.20"/>
    <param name="lost_reloc_score_margin" value="0.00"/>
    <param name="lost_reloc_min_valid_fraction" value="0.25"/>
    <param name="lost_reloc_min_interval_sec" value="0.5"/>
    <param name="lost_reloc_publish_smooth_enable" value="true"/>
    <param name="lost_reloc_publish_smooth_frames" value="4"/>
    <param name="dyn_filter_enable" value="true"/>
    <param name="dyn_grid_res_m" value="0.10"/>
    <param name="dyn_inflate_m" value="0.20"/>
    <param name="dyn_padding_m" value="5.0"/>
    <param name="dyn_keep_ratio" value="0.60"/>
    <param name="dyn_min_keep_points" value="200"/>
    <param name="dyn_hard_max_dist_m" value="2.0"/>
    <param name="dyn_ray_enable" value="true"/>
    <param name="dyn_ray_margin_near_m" value="0.20"/>
    <param name="dyn_ray_max_range_m" value="35.0"/>
    <param name="dyn_ray_hit_eps_m" value="-1.0"/>
    <param name="dyn_ray_step_m" value="-1.0"/>
    <param name="dyn_ray_max_steps" value="256"/>
    <param name="dyn_ray_confirm_df_m" value="0.15"/>
    <param name="dyn_front_protect_enable" value="true"/>
    <param name="dyn_front_protect_x_min_m" value="0.10"/>
    <param name="dyn_front_protect_x_max_m" value="3.00"/>
    <param name="dyn_front_protect_abs_y_max_m" value="0.80"/>
    <param name="dyn_front_protect_use_y_axis" value="true"/>
    <param name="dyn_front_protect_forward_sign" value="1.0"/>
    <param name="dyn_front_protect_max_drop_ratio" value="0.45"/>
    <param name="dyn_front_protect_min_in_points" value="12"/>

    <param name="optimizer_max_iterations" value="10"/>
    <param name="optimizer_corr_max_dist_m" value="0.25"/>
    <param name="optimizer_huber_delta_m" value="0.10"/>
    <param name="output_correction_gain" value="0.8"/>
    <param name="output_small_gain_scale" value="0.5"/>
    <param name="accept_small_max_corr_trans_m" value="0.03"/>
    <param name="accept_small_max_corr_yaw_deg" value="0.5"/>
    <param name="accept_quality_enable" value="true"/>
    <param name="accept_quality_min_valid_fraction" value="0.8"/>
    <param name="accept_quality_min_used_points" value="450"/>
    <param name="accept_quality_max_reject_fraction" value="0.25"/>
    <param name="accept_quality_max_mean_cost" value="0.0025"/>
    <param name="accept_quality_max_corr_trans_m" value="0.06"/>
    <param name="accept_quality_max_corr_yaw_deg" value="0.8"/>
    <param name="accept_quality_gain_scale" value="0.25"/>
    <param name="sector_degen_enable" value="true"/>
    <param name="sector_degen_min_scan_points" value="60"/>
    <param name="sector_degen_front_min_match_ratio" value="0.45"/>
    <param name="sector_degen_lr_balance_min" value="0.55"/>
    <param name="sector_degen_fb_balance_min" value="0.45"/>
    <param name="sector_degen_gain_scale" value="0.35"/>
    <param name="sector_degen_max_corr_trans_m" value="0.03"/>
    <param name="sector_degen_max_corr_yaw_deg" value="0.3"/>
    <param name="front_degen_gain_scale" value="0.6"/>
    <param name="front_degen_forward_scale" value="0.2"/>
    <param name="front_degen_lateral_scale" value="1.0"/>
    <param name="front_degen_yaw_scale" value="0.5"/>
    <param name="lr_degen_gain_scale" value="0.6"/>
    <param name="lr_degen_forward_scale" value="1.0"/>
    <param name="lr_degen_lateral_scale" value="0.25"/>
    <param name="lr_degen_yaw_scale" value="0.35"/>
    <param name="combo_degen_predictor_only" value="true"/>
    <param name="weak_dir_fusion_enable" value="true"/>
    <param name="weak_dir_min_used_points" value="200"/>
    <param name="weak_dir_cond_on" value="30.0"/>
    <param name="weak_dir_cond_bad" value="120.0"/>
    <param name="weak_dir_alpha_weak_min" value="0.05"/>
    <param name="weak_dir_alpha_strong" value="1.0"/>
    <param name="weak_dir_alpha_yaw" value="0.5"/>
    <param name="weak_dir_lambda_min_thresh" value="0.001"/>
    <param name="state_reject_to_lost_count" value="6"/>
  </node>
</launch>
